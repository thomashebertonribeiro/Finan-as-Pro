# Porta em que o servidor Node.js irá escutar
PORT=3002

# URL da instância Supabase
# Em produção (Docker/Coolify): usar URL interna da rede Docker, ex: http://supabase-kong:8000
# Em desenvolvimento local: usar http://localhost:8000
SUPABASE_URL=http://supabase-kong:8000

# Chave anon pública da instância Supabase self-hosted
# Encontrada em: Supabase Dashboard → Settings → API → anon key
SUPABASE_ANON_KEY=your-supabase-anon-key

# JWT Secret da instância Supabase self-hosted
# Encontrado em: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Chave da API Google Gemini
# Obtida em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
